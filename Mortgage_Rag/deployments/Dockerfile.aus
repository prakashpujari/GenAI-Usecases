FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY deployments/requirements.aus.txt ./requirements.aus.txt
RUN pip install --no-cache-dir -r requirements.aus.txt

COPY src ./src

EXPOSE 8000

CMD ["uvicorn", "src.aus.api:app", "--host", "0.0.0.0", "--port", "8000"]
